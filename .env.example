# Copy this file to .env and fill in the real values.
# .env is gitignored — never commit real keys.

# Supabase project settings (Project Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The variables below are NOT read by the frontend (Vite only exposes
# VITE_-prefixed vars to the browser). They're set as Supabase Edge Function
# secrets instead — see README.md "Supabase setup" — and are listed here only
# so every required value lives in one documented place.
#
# RESEND_API_KEY=re_...                     # Resend dashboard → API Keys
# EMAIL_FROM="4740 Barbershop <bookings@yourdomain.pt>"  # must be a domain verified in Resend
# DB_WEBHOOK_SECRET=choose-a-random-string   # shared secret for the DB Webhook -> send-confirmation call
# ADMIN_PASSWORD=choose-a-strong-password    # shared password for /admin
